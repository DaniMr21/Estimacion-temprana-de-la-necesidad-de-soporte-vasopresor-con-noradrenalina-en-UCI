\contentsline {figure}{\numberline {G.5}{\ignorespaces Comparación de calibración (sin calibrar / Platt / isotónica) con ECE y BSS por método.}}{74}{figure.caption.87}%
\contentsline {figure}{\numberline {G.6}{\ignorespaces Diagramas SHAP de los modelos en la ventana corta (3--12\,h), MIMIC-IV.}}{75}{figure.caption.89}%
\contentsline {figure}{\numberline {G.7}{\ignorespaces Diagramas SHAP de los modelos en la ventana media (6--24\,h), MIMIC-IV. En CatBoost la dirección del efecto de la diuresis resultó clínicamente incoherente, lo que motivó priorizar XGBoost calibrado.}}{76}{figure.caption.90}%
\contentsline {figure}{\numberline {G.8}{\ignorespaces Diagramas SHAP de los modelos en la ventana larga (12--48\,h), MIMIC-IV.}}{77}{figure.caption.91}%
