\contentsline {figure}{\numberline {G.10}{\ignorespaces Diagramas SHAP de los modelos sobre la cohorte de validación externa eICU-CRD.}}{79}{figure.caption.95}%
\contentsline {figure}{\numberline {G.11}{\ignorespaces Distribución comparada (diagramas de caja) de las variables predictoras entre MIMIC-IV (desarrollo) y eICU-CRD (validación externa). Las diferencias en \texttt {sofa\_max} ilustran el desplazamiento de distribución entre cohortes.}}{80}{figure.caption.97}%
\contentsline {figure}{\numberline {G.12}{\ignorespaces Distribución comparada de las variables de los modelos CatBoost (segundos modelos de las ventanas media y larga) entre MIMIC-IV y eICU-CRD.}}{81}{figure.caption.98}%
\contentsline {figure}{\numberline {G.13}{\ignorespaces Características basales de las cohortes de MIMIC-IV (desarrollo) y eICU-CRD (validación externa) por ventana. Variables continuas como mediana [IQR] y categóricas como $n$ (\%), con contraste de Mann-Whitney o $\chi ^2$.}}{82}{figure.caption.99}%
